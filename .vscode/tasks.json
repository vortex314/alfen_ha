{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "alfen-mqtt",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "alfen-mqtt",
                "--",
                "config.toml"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "modbus explorer",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "modbus_explorer",
                "--",
                "modbus_explorer.yaml"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "write_watch",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "write_watch",
                "--",
                "192.168.0.50",
                "502",
                "1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "alfen_solar",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "alfen_solar",
                "--",
                "config.toml"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "Build Image for Portainer",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "command": "docker",
            "args": [
                "build",
                "--build-arg",
                "APP_BIN=alfen-mqtt",
                "-t",
                "alfen-ha:local",
                "."
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Solar Image for Portainer",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "command": "docker",
            "args": [
                "build",
                "--build-arg",
                "APP_BIN=alfen_solar",
                "-t",
                "alfen-solar:local",
                "."
            ],
            "problemMatcher": []
        },
        {
            "label": "Load Solar Image to Portainer",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build Solar Image for Portainer"
            ],
            "command": "bash",
            "args": [
                "-lc",
                "docker save alfen-solar:local | curl --fail-with-body --show-error --silent --insecure -X POST '${input:portainerUrl}/api/endpoints/${input:endpointId}/docker/images/load' -H 'X-API-Key: ${input:apiKey}' -H 'Content-Type: application/x-tar' --data-binary @-"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Compose to Portainer",
            "type": "shell",
            "dependsOn": [
                "Build Image for Portainer"
            ],
            "command": "${workspaceFolder}/scripts/deploy_portainer_stack.sh",
            "args": [
                "--url",
                "${input:portainerUrl}",
                "--api-key",
                "${input:apiKey}",
                "--endpoint-id",
                "${input:endpointId}",
                "--stack-name",
                "${input:stackName}",
                "--compose-file",
                "${input:composeFile}"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Deploy alfen_solar to Portainer",
            "type": "shell",
            "dependsOn": [
                "Load Solar Image to Portainer"
            ],
            "command": "${workspaceFolder}/scripts/deploy_portainer_stack.sh",
            "args": [
                "--url",
                "${input:portainerUrl}",
                "--api-key",
                "${input:apiKey}",
                "--endpoint-id",
                "${input:endpointId}",
                "--stack-name",
                "alfen-solar",
                "--compose-file",
                "docker-compose.portainer.solar.yml"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "portainerUrl",
            "type": "promptString",
            "default": "https://pcthink.local:9443",
            "description": "Portainer base URL (without /api suffix)"
        },
        {
            "id": "endpointId",
            "type": "promptString",
            "default": "2",
            "description": "Portainer endpointId"
        },
        {
            "id": "stackName",
            "type": "promptString",
            "default": "alfen-ha",
            "description": "Portainer stack name"
        },
        {
            "id": "composeFile",
            "type": "promptString",
            "default": "docker-compose.portainer.yml",
            "description": "Compose file path"
        },
        {
            "id": "apiKey",
            "type": "promptString",
            "password": true,
            "description": "API key"

        }
    ]
}