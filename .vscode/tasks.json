{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "alfen-mqtt",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "alfen-mqtt",
                "--",
                "config.toml"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "modbus explorer",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "modbus_explorer",
                "--",
                "modbus_explorer.yaml"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "clear": true
            }
        },
        {
            "label": "write_watch",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "RUST_BACKTRACE": "full",
                    "ZENOH_PLUGINS_PATH": "/home/lieven/workspace/zenoh/target/release/"
                }
            },
            "command": "~/.cargo/bin/cargo",
            "args": [
                "run",
                "--bin",
                "write_watch",
                "--",
                "192.168.0.50",
                "502",
                "1"
            ],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "clear": true
            }
        }
    ]
}